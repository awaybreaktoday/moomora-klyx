<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="klyx.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Moomora\Klyx">
    </Installer>
    <PackageInformation
        PackageName="Klyx"
        PackageDisplayName="Klyx"
        PublisherName="CN=Moomora"
        PublisherDisplayName="Moomora"
        Version="0.1.0.0"
        PackageDescription="Platform-engineer-grade Kubernetes desktop client">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="io.moomora.klyx"
                Description="Platform-engineer-grade Kubernetes desktop client"
                DisplayName="Klyx"
                ExecutableName="klyx.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Klyx</DisplayName>
            <PublisherDisplayName>Moomora</PublisherDisplayName>
            <Description>Platform-engineer-grade Kubernetes desktop client</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="klyx.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
